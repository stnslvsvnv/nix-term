msgid "@APP_NAME@"
msgstr "@APP_NAME@"

#: data/org.gnome.Ptyxis.desktop.in.in:3
msgid "A container-oriented terminal for GNOME"
msgstr "Um terminal orientado a contêineres para GNOME"

