msgstr "terminal;prompt;ptyxis;shell;command;commandline;cmd;cli;console;container;podman;toolbox;distrobox;"

#: data/org.gnome.Ptyxis.desktop.in.in:23 src/org.gnome.Ptyxis.gschema.xml.in:424
#: src/ptyxis-preferences-window.ui:742
msgid "New Window"
msgstr "Новое окно"

#: data/org.gnome.Ptyxis.desktop.in.in:27 src/org.gnome.Ptyxis.gschema.xml.in:418
#: src/ptyxis-preferences-window.ui:771
msgid "New Tab"
msgstr "Новая вкладка"

#: data/org.gnome.Ptyxis.desktop.in.in:31 src/org.gnome.Ptyxis.gschema.xml.in:436
#: src/ptyxis-preferences-window.ui:978
msgid "Preferences"
msgstr "Параметры"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:7
msgid "Container-oriented terminal"
msgstr "Терминал ориентированный на контейнеры"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:9
msgid "Ptyxis is a terminal for GNOME that focuses on ease-of-use in a world of containers."
msgstr "Ptyxis - это терминал для GNOME, ориентированный на простоту использования в мире контейнеров."

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:13
msgid "Features:"
msgstr "Особенности:"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:15
msgid ""
"Remembers current container when opening a new tab with support for podman, toolbox, distrobox, and more"
msgstr ""
"Запоминает текущий контейнер при открытии новой вкладки с поддержкой podman, toolbox, distrobox и т. д. "

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:16
msgid "Configurable keyboard shortcuts"
msgstr "Настраиваемые комбинации клавиш"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:17
msgid "Modern interface which integrates the palette with the window styling"
msgstr "Современный интерфейс, который объединяет палитру со стилем окна"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:18
msgid "User-installable color palettes"
msgstr "Устанавливаемые пользователем цветовые палитры"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:19
msgid "Support for preferences profiles with container integration"
msgstr "Поддержка профилей предпочтений с интеграцией контейнеров"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:20
msgid "Integrated color palettes with light and dark support"
msgstr "Интегрированные цветовые палитры с поддержкой светлых и тёмных тонов"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:21
msgid "Tabbed interface with tab overviews"
msgstr "Интерфейс с вкладками и обзором вкладок"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:22
msgid "Efficient foreground process tracking denoting sudo and SSH"
msgstr "Эффективное отслеживание приоритетных процессов, обозначающее sudo и SSH"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:23
msgid "Support for transparent terminal backgrounds"
msgstr "Поддержка прозрачного фона терминала"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:24
msgid "Separate process mode for terminal-based applications"
msgstr "Отдельный режим процесса для терминальных приложений"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:25
msgid "Support for pinned tabs and saved sessions"
msgstr "Поддержка закреплённых вкладок и сохранённых сеансов"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:26
msgid "Terminal tabs are run within separate cgroups"
msgstr "Вкладки терминала запускаются в отдельных контрольных группах"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:27
msgid "Terminal inspector to help when writing terminal-based applications"
msgstr "Инспектор терминала для помощи при написании приложений на основе терминала"

#. developer_name tag deprecated with Appstream 1.0
#: data/org.gnome.Ptyxis.metainfo.xml.in.in:32
msgid "Christian Hergert"
msgstr "Christian Hergert"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:54
msgid "A column and row size indicator is displayed when resizing the window"
msgstr "Индикатор размера столбца и строки отображается при изменении размера окна"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:59
msgid "Containers are automatically discovered and displayed"
msgstr "Контейнеры автоматически обнаруживаются и отображаются"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:64
msgid "Many behaviors of the terminal may be tweaked to user preference"
msgstr "Многие функции терминала могут быть настроены в соответствии с предпочтениями пользователя"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:69
msgid "You may rename a tab by providing a prefix to the title"
msgstr "Вы можете переименовать вкладку, указав префикс к заголовку"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:74
msgid "Palettes provide an integrated dark mode"
msgstr "Палитры обеспечивают интегрированный темный режим"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:79
msgid "You can see an overview of your tabs at any time"
msgstr "Вы можете просмотреть обзор своих вкладок в любое время"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:84
msgid "Many shortcuts may be remapped to user preference"
msgstr "Многие комбинации клавиш могут быть переназначены в соответствии с предпочтениями пользователя"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:89
msgid "Built-in color palettes provide both dark and light mode variants"
msgstr "Встроенные цветовые палитры предоставляют варианты как для тёмного, так и для светлого режимов"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:94
msgid "Profiles allow for overriding a number of features such as default container"
msgstr "Профили позволяют переопределить ряд функций, таких как контейнер по умолчанию"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:99
msgid "The terminal will remind you when you're root on the local system"
msgstr "Терминал напомнит вам, когда вы являетесь пользователем root в локальной системе"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:104
msgid "The terminal will remind you when you're on a remote system"
msgstr "Терминал напомнит вам, когда вы находитесь на удалённой системе"

#: src/main.c:142 src/main.c:149 src/main.c:161
msgid "Error"
msgstr "Ошибка"

#: src/main.c:155
#, c-format
msgid ""
"Error: %s already exists.\n"
"Please remove it first.\n"
msgstr ""
"Ошибка: %s уже существует.\n"
"Пожалуйста, сначала удалите это.\n"

#: src/org.gnome.Ptyxis.gschema.xml.in:101
msgid "Default Profile UUID"
msgstr "UUID профиля по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:102
msgid "The UUID of the default profile"
msgstr "UUID профиля по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:107
msgid "UUIDs of all Profiles"
msgstr "UUID всех профилей"

#: src/org.gnome.Ptyxis.gschema.xml.in:108
msgid "A list of UUID for every profile"
msgstr "Список UUID для каждого профиля"

#: src/org.gnome.Ptyxis.gschema.xml.in:113 src/ptyxis-preferences-window.ui:322
msgid "New Tab Position"
msgstr "Позиция новой вкладки"

#: src/org.gnome.Ptyxis.gschema.xml.in:114
msgid "Where to place new tabs"
msgstr "Где размещать новые вкладки"

#: src/org.gnome.Ptyxis.gschema.xml.in:119 src/ptyxis-preferences-window.ui:414
msgid "Audible Bell"
msgstr "Звуковой сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:120
msgid "If an audible bell should be used"
msgstr "Следует ли использовать звуковой сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:125
msgid "Visible Bell"
msgstr "Визуальный сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:126
msgid "If a visual bell should be used"
msgstr "Следует ли использовать визуальный сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:131
msgid "Visual Process Leader"
msgstr "Visual Process Leader"

#: src/org.gnome.Ptyxis.gschema.xml.in:132
msgid "Display a visual window highlight when process leader is SSH, sudo, or other specialized tooling"
msgstr ""
"Отображение визуального выделения окна, когда лидером процесса является SSH, sudo или другой "
"специализированный инструмент"

#: src/org.gnome.Ptyxis.gschema.xml.in:137
msgid "Use System Font"
msgstr "Использовать системный шрифт"

#: src/org.gnome.Ptyxis.gschema.xml.in:138
msgid "If the default system monospace font should be used"
msgstr "Следует ли использовать системный моноширинный шрифт по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:143
msgid "Font Name"
msgstr "Имя шрифта"

#: src/org.gnome.Ptyxis.gschema.xml.in:144
msgid "The font description to use if use-system-font is set to False"
msgstr ""
"Описание шрифта, которое будет использоваться, если для параметра use-system-font установлено значение "
"False"

#: src/org.gnome.Ptyxis.gschema.xml.in:149 src/ptyxis-preferences-window.ui:249
msgid "Cursor Shape"
msgstr "Форма курсора"

#: src/org.gnome.Ptyxis.gschema.xml.in:150
msgid "The default shape of the cursor"
msgstr "Форма курсора по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:155
msgid "Cursor Blink Mode"
msgstr "Режим мигания курсора"

#: src/org.gnome.Ptyxis.gschema.xml.in:156
msgid "The default blink mode cursor"
msgstr "Курсор режима мигания по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:161
msgid "List of punctuation characters that are treated as word characters"
msgstr "Список знаков препинания, которые рассматриваются как символы слова"

#: src/org.gnome.Ptyxis.gschema.xml.in:162
msgid ""
"By default, when doing word-wise selection, most punctuation breaks up word boundaries. This list of "
"exceptions will instead be treated as part of the word."
msgstr ""
"По умолчанию, при выделении по словам большая часть знаков препинания разделяет слова. Вместо этого данный "
"список исключений будет рассматриваться как часть слова."

#: src/org.gnome.Ptyxis.gschema.xml.in:167
msgid "Scrollbar Policy"
msgstr "Политика полосы прокрутки"

#: src/org.gnome.Ptyxis.gschema.xml.in:168
msgid "If scrollbars should be displayed"
msgstr "Должны ли отображаться полосы прокрутки"

#: src/org.gnome.Ptyxis.gschema.xml.in:177
msgid "Text Blink Mode"
msgstr "Режим мигания текста"

#: src/org.gnome.Ptyxis.gschema.xml.in:178
msgid "When text blinking is allowed"
msgstr "Когда разрешено мигание текста"

#: src/org.gnome.Ptyxis.gschema.xml.in:183
msgid "Interface Style"
msgstr "Стиль интерфейса"

#: src/org.gnome.Ptyxis.gschema.xml.in:184
msgid "If light or dark interface style should be used"
msgstr "Следует ли использовать светлый или тёмный стиль интерфейса"

#: src/org.gnome.Ptyxis.gschema.xml.in:189 src/ptyxis-preferences-window.ui:351
msgid "Restore Session"
msgstr "Восстанавливать сеанс"

#: src/org.gnome.Ptyxis.gschema.xml.in:190
msgid "Restore tabs from previous session when starting Ptyxis"
msgstr "Восстановление вкладок предыдущего сеанса при запуске Ptyxis"

#: src/org.gnome.Ptyxis.gschema.xml.in:195 src/ptyxis-preferences-window.ui:357
msgid "Restore Window Size"
msgstr "Восстанавливать размер окна"

#: src/org.gnome.Ptyxis.gschema.xml.in:196
msgid "Restore the previous window size when creating new windows"
msgstr "Восстановление предыдущего размера окна при создании новых окон"

#: src/org.gnome.Ptyxis.gschema.xml.in:206
msgid "Default Column Size"
msgstr "Размер столбца по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:207 src/org.gnome.Ptyxis.gschema.xml.in:214
msgid "Default window size when restore-window-size is not true."
msgstr "Размер окна по умолчанию, когда значение параметра restore-window-size не равно true."

#: src/org.gnome.Ptyxis.gschema.xml.in:213
msgid "Default Row Size"
msgstr "Размер строки по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:219
msgid "Toast on Copy Clipboard"
msgstr "Всплывающее уведомление при копировании в буфер обмена"

#: src/org.gnome.Ptyxis.gschema.xml.in:220
msgid "Show the user when text has copied to the clipboard."
msgstr "Показывать пользователю, когда текст был скопирован в буфер обмена."

#: src/org.gnome.Ptyxis.gschema.xml.in:225
msgid "Enable Accessibility"
msgstr "Включить специальные возможности"

#: src/org.gnome.Ptyxis.gschema.xml.in:226
msgid "Currently experimental feature to send accessibility information to screen readers."
msgstr "Экспериментальная функция для отправки информации о доступности читателям экрана."

#: src/org.gnome.Ptyxis.gschema.xml.in:231
msgid "Enable zoom on scroll holding the control key"
msgstr "Включить масштабирование при прокрутке, удерживая клавишу ctrl"

#: src/org.gnome.Ptyxis.gschema.xml.in:232
msgid "Enable to adjust the zoom level on scroll scroll while holding the control key."
msgstr "Позволяет регулировать уровень масштабирования при прокрутке, удерживая клавишу ctrl."

#: src/org.gnome.Ptyxis.gschema.xml.in:237
msgid "Disable Padding around Terminal Emulator"
msgstr "Отключить отступы вокруг эмулятора терминала"

#: src/org.gnome.Ptyxis.gschema.xml.in:238
msgid ""
"Do not pad around the terminal emulator widget. Setting to true may have significant performance impacts."
msgstr ""
"Не использовать отступы вокруг виджета эмулятора терминала. Установка значения true может существенно "
"повлиять на производительность."

#: src/org.gnome.Ptyxis.gschema.xml.in:243
msgid "Prompt when active tab is closed"
msgstr "Предупреждать о закрытии активной вкладки"

#: src/org.gnome.Ptyxis.gschema.xml.in:244
msgid "If a tab (or window) is closed with active foreground processes, prompt the user for confirmation."
msgstr ""
"Если вкладка (или окно) закрывается с активными процессами на переднем плане, запросить у пользователя "
"подтверждение."

#. Translators: OSC stands for "Operating System Command" and is referencing in-band escape sequences from the child process to set the title
#: src/org.gnome.Ptyxis.gschema.xml.in:250
msgid "Ignore OSC Title"
msgstr "Игнорировать заголовок OSC"

#: src/org.gnome.Ptyxis.gschema.xml.in:251
msgid "If OSC title should be ignored in tab titles."
msgstr "Следует ли игнорировать заголовок OSC в заголовках вкладок."

#: src/org.gnome.Ptyxis.gschema.xml.in:256
msgid "Inhibit Logout"
msgstr "Запретить выход из системы"

#: src/org.gnome.Ptyxis.gschema.xml.in:257
msgid "Inhibit desktop logout when a foreground process is running in a tab."
msgstr "Запретить выход из системы на рабочий стол, когда на вкладке запущен процесс переднего плана."

#: src/org.gnome.Ptyxis.gschema.xml.in:266
msgid "Label"
msgstr "Метка"

#: src/org.gnome.Ptyxis.gschema.xml.in:267
msgid "The label for the profile"
msgstr "Метка для профиля"

#: src/org.gnome.Ptyxis.gschema.xml.in:272
msgid "Login Shell"
msgstr "Оболочка входа"

#: src/org.gnome.Ptyxis.gschema.xml.in:273
msgid "Use a login shell"
msgstr "Использовать оболочку входа"

#: src/org.gnome.Ptyxis.gschema.xml.in:278 src/ptyxis-preferences-window.ui:482
#: src/ptyxis-profile-editor.ui:333
msgid "Limit Scrollback"
msgstr "Ограничить обратную прокрутку"

#: src/org.gnome.Ptyxis.gschema.xml.in:279
msgid "Limit the number of lines to keep for scrollback"
msgstr "Ограничить количество строк, сохраняемых для обратной прокрутки"

#: src/org.gnome.Ptyxis.gschema.xml.in:285 src/ptyxis-preferences-window.ui:491
#: src/ptyxis-profile-editor.ui:342
msgid "Scrollback Lines"
msgstr "Строки для обратной прокрутки"

#: src/org.gnome.Ptyxis.gschema.xml.in:286
msgid "The number of lines to keep in the scrollback, zero for no scrollback"
msgstr "Количество строк, сохраняемых для обратной прокрутки, 0 для отключения прокрутки"

#: src/org.gnome.Ptyxis.gschema.xml.in:291 src/ptyxis-preferences-window.ui:472
#: src/ptyxis-profile-editor.ui:323
msgid "Scroll on Output"
msgstr "Прокрутка при выводе"

#: src/org.gnome.Ptyxis.gschema.xml.in:292
msgid "Scroll to the bottom upon new output"
msgstr "Прокрутить вниз при появлении нового вывода"

#: src/org.gnome.Ptyxis.gschema.xml.in:297 src/ptyxis-preferences-window.ui:466
#: src/ptyxis-profile-editor.ui:317
msgid "Scroll on Keystroke"
msgstr "Прокрутка при нажатии клавиш"

#: src/org.gnome.Ptyxis.gschema.xml.in:298
msgid "Scroll to the bottom upon user keystroke"
msgstr "Прокрутить вниз при нажатии клавиш пользователем"

#: src/org.gnome.Ptyxis.gschema.xml.in:303 src/ptyxis-profile-editor.ui:187
msgid "Use Custom Command"
msgstr "Использовать пользовательскую команду"

#: src/org.gnome.Ptyxis.gschema.xml.in:304
msgid "If a custom command should be used"
msgstr "Следует ли использовать пользовательскую команду"

#: src/org.gnome.Ptyxis.gschema.xml.in:309
msgid "Use Proxy"
msgstr "Использовать прокси"

#: src/org.gnome.Ptyxis.gschema.xml.in:310
msgid "Apply proxy settings from the host in the container"
msgstr "Применить настройки прокси с хоста в контейнере"

#: src/org.gnome.Ptyxis.gschema.xml.in:315 src/ptyxis-profile-editor.ui:192
msgid "Custom Command"
msgstr "Пользовательская команда"

#: src/org.gnome.Ptyxis.gschema.xml.in:316
msgid "A custom command for the shell"
msgstr "Пользовательская команда для оболочки"

#: src/org.gnome.Ptyxis.gschema.xml.in:321 src/ptyxis-profile-editor.ui:211
msgid "Default Container"
msgstr "Контейнер по умолчанию"

#: src/org.gnome.Ptyxis.gschema.xml.in:322
msgid "The default container to run the command in"
msgstr "Контейнер по умолчанию для запуска команды"

#: src/org.gnome.Ptyxis.gschema.xml.in:327 src/ptyxis-profile-editor.ui:220
msgid "Preserve Container"
msgstr "Сохранять контейнер"

#: src/org.gnome.Ptyxis.gschema.xml.in:328
msgid "Preserve the active container when creating new tabs and windows"
msgstr "Сохранять активный контейнер при создании новых вкладок и окон"

#: src/org.gnome.Ptyxis.gschema.xml.in:333 src/ptyxis-preferences-window.ui:551
#: src/ptyxis-profile-editor.ui:281
msgid "Exit Action"
msgstr "Действие при завершении"

#: src/org.gnome.Ptyxis.gschema.xml.in:334
msgid "The action to take when the shell exits"
msgstr "Действие, которое необходимо предпринять при завершении оболочки"

#: src/org.gnome.Ptyxis.gschema.xml.in:339
msgid "Preserve Directory"
msgstr "Сохранять каталог"

#: src/org.gnome.Ptyxis.gschema.xml.in:340
msgid "If the directory should be preserved for new terminals"
msgstr "Сохранять ли каталог для новых терминалов"

#: src/org.gnome.Ptyxis.gschema.xml.in:345 src/ptyxis-inspector.ui:102 src/ptyxis-preferences-window.ui:40
#: src/ptyxis-profile-editor.ui:65
msgid "Palette"
msgstr "Палитра"

