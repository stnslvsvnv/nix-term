#: data/org.gnome.Ptyxis.desktop.in.in:2 data/org.gnome.Ptyxis.metainfo.xml.in.in:6
msgid "@APP_NAME@"
msgstr "@APP_NAME@"

#: data/org.gnome.Ptyxis.desktop.in.in:3
msgid "A container-oriented terminal for GNOME"
msgstr "Ein auf Container ausgerichtetes Terminal für GNOME"

#: data/org.gnome.Ptyxis.desktop.in.in:12 src/ptyxis-preferences-window.ui:669 src/ptyxis-tab.c:1624 src/ptyxis-util.c:318
msgid "Terminal"
msgstr "Terminal"

