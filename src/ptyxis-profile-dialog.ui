<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="PtyxisProfileDialog" parent="AdwDialog">
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="AdwWindowTitle">
                <property name="title" translatable="yes">Change Profile</property>
              </object>
            </property>
          </object>
        </child>
        <property name="content">
          <object class="AdwPreferencesGroup">
            <property name="margin-bottom">18</property>
            <property name="margin-end">18</property>
            <property name="margin-start">18</property>
            <property name="margin-top">9</property>
            <child>
              <object class="AdwComboRow" id="profile_combo">
                <property name="title" translatable="yes">Profile</property>
                <property name="subtitle" translatable="yes">Select a profile to apply to this terminal</property>
                <property name="expression">
                  <lookup name="label" type="PtyxisProfile"/>
                </property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>

